# FinSight AI — Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# REQUIRED
# ============================================================
# Get your free API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
# OPTIONAL — Enhanced news coverage
# ============================================================
# Free tier: https://newsapi.org/register (100 req/day)
NEWSAPI_KEY=

# Free tier: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ============================================================
# INFRASTRUCTURE — defaults are fine for local dev
# ============================================================
DATABASE_URL=sqlite:///./finsight.db
CHROMA_PERSIST_DIR=.chroma_data
CACHE_DIR=.cache_data
PDF_OUTPUT_DIR=.reports
MCP_SERVER_URL=http://localhost:8001

# ============================================================
# LOGGING & PERFORMANCE
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# FASTAPI
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
# STREAMLIT
# ============================================================
STREAMLIT_SERVER_PORT=8501
